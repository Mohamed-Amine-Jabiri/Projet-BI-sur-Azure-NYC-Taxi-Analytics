{
	"name": "DF_Clean_Trips",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_RAW",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_CURATED",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "GestionValeursNulles"
				},
				{
					"name": "Suppressiondesdonneesincoherentes"
				},
				{
					"name": "Creationdescolonnescalculees"
				},
				{
					"name": "aggregate1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          VendorID as integer,",
				"          tpep_pickup_datetime as timestamp,",
				"          tpep_dropoff_datetime as timestamp,",
				"          passenger_count as long,",
				"          trip_distance as double,",
				"          RatecodeID as long,",
				"          store_and_fwd_flag as string,",
				"          PULocationID as integer,",
				"          DOLocationID as integer,",
				"          payment_type as long,",
				"          fare_amount as double,",
				"          extra as double,",
				"          mta_tax as double,",
				"          tip_amount as double,",
				"          tolls_amount as double,",
				"          improvement_surcharge as double,",
				"          total_amount as double,",
				"          congestion_surcharge as double,",
				"          Airport_fee as double,",
				"          cbd_congestion_fee as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> source1",
				"source1 derive(passenger_count = coalesce(passenger_count, 1),",
				"          fare_amount = coalesce(fare_amount, 0.0),",
				"          tip_amount =  coalesce(tip_amount, 0.0),",
				"          total_amount = coalesce(total_amount, 0.0),",
				"          extra = coalesce(extra, 0.0),",
				"          mta_tax = coalesce(mta_tax, 0.0),",
				"          tolls_amount = coalesce(tolls_amount, 0.0),",
				"          improvement_surcharge = coalesce(improvement_surcharge, 0.0),",
				"          congestion_surcharge = coalesce(congestion_surcharge, 0.0),",
				"          cbd_congestion_fee = coalesce(cbd_congestion_fee, 0.0),",
				"          store_and_fwd_flag = coalesce(store_and_fwd_flag, 'N')) ~> GestionValeursNulles",
				"GestionValeursNulles filter(trip_distance > 0 &&",
				"fare_amount >= 0 &&",
				"total_amount >= 0 &&",
				"passenger_count > 0) ~> Suppressiondesdonneesincoherentes",
				"aggregate1 derive(revenue = fare_amount + tip_amount,",
				"          tip_percentage = iif(fare_amount == 0.0, toDouble(0), toDouble(tip_amount / fare_amount) * 100),",
				"          total_fees = extra + mta_tax + tolls_amount + improvement_surcharge + congestion_surcharge + Airport_fee + cbd_congestion_fee,",
				"          trip_type = iif(trip_distance < 5,'Short Trip','Long Trip')) ~> Creationdescolonnescalculees",
				"Suppressiondesdonneesincoherentes aggregate(groupBy(VendorID,",
				"          tpep_pickup_datetime,",
				"          tpep_dropoff_datetime,",
				"          PULocationID,",
				"          DOLocationID,",
				"          trip_distance,",
				"          fare_amount,",
				"          total_amount,",
				"          payment_type),",
				"     passenger_count = first(passenger_count),",
				"          RatecodeID = first(RatecodeID),",
				"          store_and_fwd_flag = first(store_and_fwd_flag),",
				"          extra = first(extra),",
				"          mta_tax = first(mta_tax),",
				"          tip_amount = first(tip_amount),",
				"          tolls_amount = first(tolls_amount),",
				"          improvement_surcharge = first(improvement_surcharge),",
				"          congestion_surcharge =  first(congestion_surcharge),",
				"          Airport_fee = first(Airport_fee),",
				"          cbd_congestion_fee = first(cbd_congestion_fee)) ~> aggregate1",
				"Creationdescolonnescalculees sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}